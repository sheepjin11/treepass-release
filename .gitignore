# Smoke run produces a SplinterDB data file at $DB_PATH/dbfile;
# the default --db-path is the repo root.
/dbfile

# Baseline backends (CLOCK1/2/3, S3-FIFO) — cloned locally, not tracked.
/third_party/

# Re-include tracked build inputs that the broad SplinterDB patterns above
# (*/*.txt, */*/config.h) would otherwise drop. These are source files, not
# generated artifacts.
!**/CMakeLists.txt
!bench/common/config.h
!splinterdb/tests/config.h
